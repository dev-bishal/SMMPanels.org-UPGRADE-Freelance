---
import { metaData } from '../pages/data';
import { metaDataEs } from '../pages/es/data';
import { metaDataFr } from '../pages/fr/data';
import { metaDataPt } from '../pages/pt/data';
import { metaDataRu } from '../pages/ru/data';
import { metaDataZh } from '../pages/zh/data';
import { metaDataHi } from '../pages/hi/data';
import { metaDataBn } from "../pages/bn/data";
import { metaDataUr } from "../pages/ur/data";
import { metaDataId } from "../pages/id/data";

import Button from './Button.astro';

interface Props {
    panelTitle: string;
    panelUrl: string;
    imgSrc: string;
    avrg ?: number;
    rating : number,
    lang ?: string;
}

const {imgSrc, panelTitle, panelUrl, rating, lang = "en"} = Astro.props;

let contentPath;
if(lang == "en") contentPath = metaData;
else if(lang == "ru") contentPath = metaDataRu;
else if(lang == "zh") contentPath = metaDataZh
else if(lang == "es") contentPath = metaDataEs
else if(lang == "fr") contentPath = metaDataFr
else if(lang == "pt") contentPath = metaDataPt
else if(lang == "hi") contentPath = metaDataHi
else if(lang == "bn") contentPath = metaDataBn
else if(lang == "ur") contentPath = metaDataUr
else if(lang == "id") contentPath = metaDataId

var ratingCollection : String[] = [];
for (let j = 0; j < 5; j++) {
    if(j < rating)
        ratingCollection.push("fa-solid fa-star");
    else
        ratingCollection.push("fa-regular fa-star");
}

let langDirectory = "";
if(lang != "en"){
    langDirectory = "/"+ lang
}
---

<article class="rounded-lg bg-[#d3d3d3] dark:bg-[#202123] lg:w-[31%] md:w-[45%] w-full">
    <img src={imgSrc} alt={panelTitle} class="panelThumbnail hover:brightness-90 cursor-pointer w-full h-[200px] object-cover rounded-t-lg" />
    <div class="panel-data p-3">
        <div class="head w-full flex flex-col justify-center items-center gap-1">
            <a class="font-semibold dark:hover:text-[#9bdd75] hover:text-black" href={langDirectory + "/panels/"+panelUrl}>
                <h2>{panelTitle}</h2>
            </a>

        </div>
        <div class="footer w-full flex justify-between items-center text-xs">
            <Button url={langDirectory + "/panels/"+panelUrl} text={contentPath?.text[6] || ""} iconClass="fa-solid fa-arrow-right"/>
            
            <p>
                <span class="text-gray-600 dark:text-gray-400"><i class="fa-duotone fa-solid fa-stars"></i> {contentPath?.text[12]}: </span>
                <span class="text-black dark:text-white">{rating} {contentPath?.text[14]}</span>
            </p>
        </div>
    </div>
</article>