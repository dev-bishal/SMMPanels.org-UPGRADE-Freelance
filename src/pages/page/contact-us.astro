---
import { getAPIPath, JsonToHtml } from "../../data/utils";
import MainLayout from "../../layouts/MainLayout.astro";
import { metaData } from "../data";
//Pages API for Contact Page Content Only
const allPagesFetch: any = await fetch(getAPIPath() + "pages").then(
    (Response) => Response.json(),
);
var page;

for (let i = 0; i < allPagesFetch.length; i++) {
    if (allPagesFetch[i].pageTitle.toLowerCase().includes("contact")) {
        page = allPagesFetch[i];
        break;
    }
}

const allSiteFetch:any = await fetch(getAPIPath() + "siteSettings/" + import.meta.env.SITESETTINGSKEY).then(Response => Response.json());
---

<MainLayout 
    siteTitle = {allSiteFetch.SiteTitle}
    title={allSiteFetch.SiteTitle + " - Contact Us"}
    lang={metaData.language}
    metaDescription=""
    pageType="page"
>
    <div
        class="content-wrapper content p-6 bg-[#d3d3d3] dark:bg-[#202123] rounded-lg my-5 dark:text-white text-[#202123] flex flex-wrap lg:justify-start justify-center gap-5 px-5"
    >
        <article class="leading-8">
            <h1>{page.pageTitle}</h1>
            <div
                class="content"
                set:html={JsonToHtml({time : 1610972762955, blocks : page.pageContent})}
            />

            <div
                class="responseMessage hidden w-full justify-center items-center flex-col gap-3"
            >
                <p class="font-bold text-center text-3xl my-4"></p>
                <a href="/" class="rounded px-4 py-2 hover:bg-[#69b63d] bg-[#9bdd75] text-white"
                    ><i class="fa-solid fa-house"></i> Home</a
                >
            </div>

            <form
                id="contactFrm"
                method="post"
                class="flex flex-col justify-center items-center mt-3 w-full"
            >
                <div
                    class="fields-container z-[1] w-full flex flex-col gap-3 p-4 rounded"
                >
                    <h2 class="text-xl font-bold text-left w-full mb-4">
                        Write your message -
                    </h2>
                    <input
                        required
                        class="border-gray-500 border shadow-md shadow-slate-800 dark:text-white text-slate-800 px-3 py-2 rounded-md"
                        type="text"
                        name="contact_name"
                        id="contact_name"
                        placeholder="Your Name"
                    />
                    <input
                        required
                        class="border-gray-500 border shadow-md shadow-slate-800 dark:text-white text-slate-800 px-3 py-2 rounded-md"
                        type="email"
                        name="contact_email"
                        id="contact_email"
                        placeholder="Email Address"
                    />
                    <textarea
                        required
                        class="border-gray-500 border shadow-md shadow-slate-800 dark:text-white text-slate-800 px-3 py-2 rounded-md min-h-32"
                        name="contact_msg"
                        id="contact_msg"
                        placeholder="Your Message"></textarea>

                    <!-- Captcha -->
                    <div
                        class="my-3 g-recaptcha"
                        data-sitekey={import.meta.env.CapchaSiteKey}
                    >
                    </div>
                    <span class="grid place-items-center">
                        <button
                            id="sendMsgBtn"
                            type="submit"
                            class="hover:bg-[#69b63d] bg-[#9bdd75] group text-black rounded-full gap-2 flex items-center px-3 py-2 w-fit"
                            >Send Message <i class="fa-solid fa-paper-plane-top"
                            ></i></button
                        >
                    </span>
                </div>
            </form>
        </article>
    </div>
</MainLayout>

<script is:inline src="https://www.google.com/recaptcha/api.js" async defer
></script>

<style is:inline>
    article h1 {
        font-size: 22px;
        font-weight: 600;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h1 {
        font-size: 22px;
        font-weight: 600;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h2 {
        font-size: 20px;
        font-weight: 500;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h3 {
        font-size: 19px;
        font-weight: 500;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h4 {
        font-size: 17px;
        font-weight: 500;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h5 {
        font-size: 16px;
        font-weight: 500;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content h6 {
        font-size: 15px;
        font-weight: 500;
        padding-bottom: 15px;
        padding-top: 10px;
    }
    .content ol {
        list-style-type: decimal;
        padding-left: 2rem;
    }
    .content p {
        padding-bottom: 15px;
    }

    article .content a {
        color: #ff78ec;
    }
    article .content a:hover {
        text-decoration-line: underline;
    }
</style>

<script is:inline define:vars={{ API: getAPIPath() }}>
    const form = document.getElementById("contactFrm");
    const responseSection = document.querySelector(".responseMessage");
    function handleForm(event) {
        event.preventDefault();
    }
    form.addEventListener("submit", handleForm);

    const sendMsgBtn = document.querySelector("#sendMsgBtn");
    sendMsgBtn.addEventListener("click", () => {
        let data = new FormData(form);
        
        if(data.get("contact_name").toString() != "" || data.get("contact_email").toString() != "" || data.get("contact_msg").toString() != ""){
            fetch(`${API}api/messages.json`, {
            // fetch(`http://localhost:4322/api/messages.json`, {
                method: "POST",
                body: data,
            })
            .then((response) => response.json())
            .then((data) => {
                if (data.message.includes("Message Saved into Database")) {
                    responseSection.classList.add("flex");
                    responseSection.classList.remove("hidden");
                    responseSection.querySelector("p").textContent =
                        "Thank You for contacting us. We will reach out to soon!!";
                    form.remove();
                } else {
                    responseSection.classList.add("flex");
                    responseSection.classList.remove("hidden");
                    responseSection.querySelector("p").textContent =
                        "A Problem occured. Your Message could not be sent.";
                    form.remove();
                }
            });
        }
        else{
            alert("Please fill all the Details")
        }
    });
</script>
