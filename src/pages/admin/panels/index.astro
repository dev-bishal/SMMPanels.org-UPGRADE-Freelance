---
import { isAdminLoggedIn } from "../../../data/admin-utils";
import { getAPIPath, getImageBasePath } from "../../../data/utils";
import AdminLayout from "../../../layouts/AdminLayout.astro";


const adminCookie = Astro.cookies.get("admin");

//#region Authentication
if(!isAdminLoggedIn(adminCookie)){
    return Astro.redirect("/admin/login");
}

const response = await fetch(getAPIPath() + `auth/validate`, {
	method: "POST",
    body : JSON.stringify({ userId : adminCookie?.value}),
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
}).then(res => res.json());

// console.log(response);

if(response.status !== 200 && response.isValid !== true){
    return Astro.redirect("/admin/login");
}
//#endregion
---

<style is:inline>
    .article-table {
        border-collapse: separate;
        border-spacing: 0;
    }

    .article-table th {
        position: sticky;
        top: 0;
        background-color: #f8fafc;
        z-index: 10;
    }

    .article-table tr:hover {
        background-color: #f1f5f9;
    }

    .status-published {
        background-color: #10b981;
    }

    .status-draft {
        background-color: #f59e0b;
    }

    .status-scheduled {
        background-color: #3b82f6;
    }

    .fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }

    @keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .loading-spinner {
        border: 3px solid #f3f3f3;
        border-top: 3px solid #3498db;
        border-radius: 50%;
        width: 30px;
        height: 30px;
        animation: spin 1s linear infinite;
        margin: 20px auto;
    }
    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>
<AdminLayout PageTitle="Panels" PageHeader="Panels" UserName={response.user.fullname || response.user.username} avatarImagePath={getImageBasePath() + response.user.ProfilePic} emailAdd = {response.user.email}>

    <!-- Main Content -->
    <main class="mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Filters and Search -->
        <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between space-y-4 md:space-y-0">
                <div class="flex-1">
                    <div class="relative max-w-xs">
                        <input type="text" id="search-panels" placeholder="Search panels..."
                            class="pl-10 pr-4 py-2 w-full border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-400"></i>
                        </div>
                    </div>
                </div>
                <div class="flex space-x-4">
                    <a href="panels/editor" class="bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg flex items-center">
                        <i class="fas fa-plus mr-2"></i> New panel
                    </a>
                </div>
            </div>
        </div>

        <!-- Panels Table -->
        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full article-table">
                    <thead>
                        <tr class="text-left text-gray-500 text-sm font-medium">
                            <th class="py-3 px-6">Panel Name</th>
                            <th class="py-3 px-6">Last Update Date</th>
                            <th class="py-3 px-6">API Link</th>
                            <th class="py-3 px-6">API Key</th>
                            <th class="py-3 px-6">Is API Working</th>
                            <th class="py-3 px-6 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="text-gray-700 divide-y divide-gray-200" id="panels-table-body">
                        <!-- Panels will be populated here by JavaScript -->
                    </tbody>
                </table>
                <div id="loading-indicator" class="hidden">
                    <div class="loading-spinner"></div>
                    <p class="text-center text-gray-500 mt-2">Loading panels...</p>
                </div>
                <div id="no-panels-message" class="hidden p-8 text-center">
                    <i class="fas fa-file-alt text-4xl text-gray-300 mb-4"></i>
                    <p class="text-gray-500">No panels found.</p>
                </div>
                <div id="error-message" class="hidden p-8 text-center">
                    <i class="fas fa-exclamation-triangle text-4xl text-red-300 mb-4"></i>
                    <p class="text-red-500">Failed to load panels. Please try again later.</p>
                    <button id="retry-button"
                        class="mt-4 bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg">
                        Retry
                    </button>
                </div>
            </div>

            <!-- Pagination -->
            <div
                class="px-6 py-4 border-t border-gray-200 flex flex-col sm:flex-row items-center justify-between space-y-4 sm:space-y-0">
                <div class="flex items-center space-x-4">
                    <div class="text-sm text-gray-700">
                        Showing <span id="current-start">0</span> to <span id="current-end">0</span> of <span
                            id="total-panels">0</span> results
                    </div>
                    <div class="flex items-center space-x-2">
                        <span class="text-sm text-gray-700">Show</span>
                        <div class="relative">
                            <select id="items-per-page"
                                class="appearance-none bg-white pl-3 pr-8 py-1 border border-gray-300 rounded focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500">
                                <option value="5">5</option>
                                <option value="10" selected>10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                            <div
                                class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-1 text-gray-700">
                                <i class="fas fa-chevron-down text-xs"></i>
                            </div>
                        </div>
                        <span class="text-sm text-gray-700">per page</span>
                    </div>
                </div>
                <div class="flex items-center space-x-1" id="pagination-buttons">
                    <!-- Pagination buttons will be generated here -->
                </div>
            </div>
        </div>
    </main>


</AdminLayout>

<script is:inline define:vars={{key:import.meta.env.API_SECURITY_KEY, APIUrl : getAPIPath()}}>

    // Pagination state
    let currentPage = 1;
    let itemsPerPage = 10;
    let allPanels = [];
    let filteredPanels = [];
    let isLoading = false;
    
    localStorage.removeItem("edit-panel");

    // Format date to readable format
    function formatDate(dateString) {
        const options = { year: 'numeric', month: 'short', day: 'numeric' };
        return new Date(dateString).toLocaleDateString(undefined, options);
    }

    // Show/hide loading indicator
    function setLoading(loading) {
        isLoading = loading;
        const loadingIndicator = document.getElementById('loading-indicator');
        const tableBody = document.getElementById('panels-table-body');

        if (loading) {
            loadingIndicator.classList.remove('hidden');
            tableBody.classList.add('hidden');
            document.getElementById('no-panels-message').classList.add('hidden');
            document.getElementById('error-message').classList.add('hidden');
        } else {
            loadingIndicator.classList.add('hidden');
            tableBody.classList.remove('hidden');
        }
    }

    // Show error message
    function showError() {
        setLoading(false);
        document.getElementById('panels-table-body').classList.add('hidden');
        document.getElementById('no-panels-message').classList.add('hidden');
        document.getElementById('error-message').classList.remove('hidden');
    }

    // Show no panels message
    function showNoPanels() {
        document.getElementById('panels-table-body').classList.add('hidden');
        document.getElementById('no-panels-message').classList.remove('hidden');
        document.getElementById('error-message').classList.add('hidden');
    }

    // Fetch panels from API
    async function fetchPanels() {
        setLoading(true);

        try {
            // In a real application, you would use your actual API endpoint
            // For demonstration, we'll use JSONPlaceholder and transform the data
            const response = await fetch(APIUrl + `panels`, {
                method: "GET",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            console.log(data);
            
            // Transform the data to match our expected format
            // In a real application, your API would likely return data in the correct format
            allPanels = data.map((item, index) => {
                // Generate realistic data based on the index
                return {
                    id: item._id,
                    title: item.panelTitle,
                    publishDate: item.createdAt,
                    APILink: item.panelAPILink,
                    APIKey: item.panelAPIKey,
                    status: item.isAPIWorking,
                };
            });

            // Apply any existing filters
            filterPanels();
            setLoading(false);

        } catch (error) {
            console.error('Error fetching panels:', error);
            showError();
        }
    }

    // Get current page panels
    function getCurrentPagePanels() {
        const startIndex = (currentPage - 1) * itemsPerPage;
        const endIndex = startIndex + itemsPerPage;
        return filteredPanels.slice(startIndex, endIndex);
    }

    // Render panels table
    function renderPanels() {
        const tableBody = document.getElementById('panels-table-body');
        tableBody.innerHTML = '';

        const currentPanels = getCurrentPagePanels();

        if (currentPanels.length === 0) {
            showNoPanels();
            return;
        }

        tableBody.classList.remove('hidden');
        document.getElementById('no-panels-message').classList.add('hidden');
        document.getElementById('error-message').classList.add('hidden');

        currentPanels.forEach(panel => {
            const row = document.createElement('tr');
            row.className = 'fade-in';
            
            row.innerHTML = `
                <td class="py-4 px-6 whitespace-nowrap">
                    <div class="flex items-center">
                        <div class="h-10 w-10 flex-shrink-0 bg-gray-200 rounded-lg flex items-center justify-center">
                            <i class="fas fa-file-alt text-gray-500"></i>
                        </div>
                        <div class="ml-4">
                            <div class="font-medium text-gray-900">${panel.title}</div>
                        </div>
                    </div>
                </td>
                <td class="py-4 px-6 whitespace-nowrap">
                    <div class="text-sm">${formatDate(panel.publishDate)}</div>
                </td>
                <td class="py-4 px-6 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">${panel.APILink}</span>
                </td>
                <td class="py-4 px-6 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800 max-w-64 overflow-hidden">${panel.APIKey}</span>
                </td>
                <td class="py-4 px-6 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full text-white ${panel.status ? "status-published" : "status-draft"}">
                        ${panel.status ? "Yes" : "No"}
                    </span>
                </td>
                <td class="py-4 px-6 whitespace-nowrap text-right text-sm font-medium">
                    <button class="text-blue-600 hover:text-blue-900 mr-3 translate-panel" data-id="${panel.id}">
                        <i class="fa-solid fa-language mr-1"></i> Translate
                    </button>
                    <button class="text-blue-600 hover:text-blue-900 mr-3 edit-panel" data-id="${panel.id}">
                        <i class="fas fa-edit mr-1"></i> Edit
                    </button>
                    <button class="text-red-600 hover:text-red-900 delete-panel" data-id="${panel.id}">
                        <i class="fas fa-trash mr-1"></i> Delete
                    </button>
                </td>
            `;

            tableBody.appendChild(row);
        });

        // Update pagination info
        const startIndex = (currentPage - 1) * itemsPerPage + 1;
        const endIndex = Math.min(startIndex + itemsPerPage - 1, filteredPanels.length);

        document.getElementById('current-start').textContent = startIndex;
        document.getElementById('current-end').textContent = endIndex;
        document.getElementById('total-panels').textContent = filteredPanels.length;

        // Add event listeners to action buttons
        document.querySelectorAll('.translate-panel').forEach(button => {
            button.addEventListener('click', () => {
                const panelId = button.getAttribute('data-id');
                translateData(panelId)
            });
        });

        document.querySelectorAll('.edit-panel').forEach(button => {
            button.addEventListener('click', () => {
                const panelId = button.getAttribute('data-id');
                localStorage.setItem("edit-panel", panelId);
                window.location.href = "/admin/panels/editor"
            });
        });
        
        document.querySelectorAll('.delete-panel').forEach(button => {
            button.addEventListener('click', () => {

                const panelId = button.getAttribute('data-id');
                
                // Show Delete modal if Yes proceed else return
                showDeleteModal().then(resp => {
                    if (resp === 'Delete Clicked') {
                        // Perform delete operation
                        deleteData(panelId)
                        console.log('Deleting item...');
                    }
                });
            });
        });
    }

    async function translateData(panelId) {
        showLoadingModal();
        try {
            const response = await fetch(APIUrl + `panels/translate/${panelId}`, {
                method: "PUT",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
            
            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            // console.log(data);

            toastSystem.show({
                type: 'success',
                title: 'Panel Translated',
                message: `Requested Panel Content Translated`,
                duration: 6000
            });

        } catch (error) {
            console.error('Error deleting panel:', error);
            toastSystem.show({
                type: 'error',
                title: 'Panel Delete error',
                message: `An Error occured while deleting`,
                duration: 6000
            });
        }
        modalSystem.closeAll();
    }

    async function deleteData(panelId) {
        showLoadingModal();
        try {
            const response = await fetch(APIUrl + `panels/${panelId}`, {
                method: "DELETE",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });

            if (!response.ok) {
                throw new Error(`HTTP error! status: ${response.status}`);
            }

            const data = await response.json();
            // console.log(data);

            toastSystem.show({
                type: 'success',
                title: 'Panel Delete',
                message: `Requested Panel is deleted`,
                duration: 6000
            });
            fetchPanels();

        } catch (error) {
            console.error('Error deleting panel:', error);
            toastSystem.show({
                type: 'error',
                title: 'Panel Delete error',
                message: `An Error occured while deleting`,
                duration: 6000
            });
        }
        modalSystem.closeAll();
    }

    // Render pagination buttons
    function renderPaginationButtons() {
        const totalPages = Math.ceil(filteredPanels.length / itemsPerPage);
        const paginationContainer = document.getElementById('pagination-buttons');
        paginationContainer.innerHTML = '';

        if (totalPages <= 1) return;

        // Previous button
        const prevButton = document.createElement('button');
        prevButton.className = 'px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50';
        prevButton.innerHTML = '<i class="fas fa-chevron-left"></i>';
        prevButton.disabled = currentPage === 1;
        prevButton.addEventListener('click', () => {
            if (currentPage > 1) {
                currentPage--;
                renderPanels();
                renderPaginationButtons();
            }
        });
        paginationContainer.appendChild(prevButton);

        // Page number buttons
        const maxVisibleButtons = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxVisibleButtons / 2));
        let endPage = Math.min(totalPages, startPage + maxVisibleButtons - 1);

        // Adjust start page if we're near the end
        if (endPage - startPage + 1 < maxVisibleButtons) {
            startPage = Math.max(1, endPage - maxVisibleButtons + 1);
        }

        // First page button if needed
        if (startPage > 1) {
            const firstButton = document.createElement('button');
            firstButton.className = 'px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50';
            firstButton.textContent = '1';
            firstButton.addEventListener('click', () => {
                currentPage = 1;
                renderPanels();
                renderPaginationButtons();
            });
            paginationContainer.appendChild(firstButton);

            // Ellipsis if needed
            if (startPage > 2) {
                const ellipsis = document.createElement('span');
                ellipsis.className = 'px-2 text-gray-500';
                ellipsis.textContent = '...';
                paginationContainer.appendChild(ellipsis);
            }
        }

        // Page number buttons
        for (let i = startPage; i <= endPage; i++) {
            const pageButton = document.createElement('button');
            pageButton.className = `px-3 py-1 rounded border ${i === currentPage ? 'border-blue-500 bg-blue-50 text-blue-600 pagination-btn active' : 'border-gray-300 text-gray-600 hover:bg-gray-50'}`;
            pageButton.textContent = i;
            pageButton.addEventListener('click', () => {
                currentPage = i;
                renderPanels();
                renderPaginationButtons();
            });
            paginationContainer.appendChild(pageButton);
        }

        // Last page button if needed
        if (endPage < totalPages) {
            // Ellipsis if needed
            if (endPage < totalPages - 1) {
                const ellipsis = document.createElement('span');
                ellipsis.className = 'px-2 text-gray-500';
                ellipsis.textContent = '...';
                paginationContainer.appendChild(ellipsis);
            }

            const lastButton = document.createElement('button');
            lastButton.className = 'px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50';
            lastButton.textContent = totalPages;
            lastButton.addEventListener('click', () => {
                currentPage = totalPages;
                renderPanels();
                renderPaginationButtons();
            });
            paginationContainer.appendChild(lastButton);
        }

        // Next button
        const nextButton = document.createElement('button');
        nextButton.className = 'px-3 py-1 rounded border border-gray-300 text-gray-600 hover:bg-gray-50';
        nextButton.innerHTML = '<i class="fas fa-chevron-right"></i>';
        nextButton.disabled = currentPage === totalPages;
        nextButton.addEventListener('click', () => {
            if (currentPage < totalPages) {
                currentPage++;
                renderPanels();
                renderPaginationButtons();
            }
        });
        paginationContainer.appendChild(nextButton);
    }

    // Filter panels based on search and filters
    function filterPanels() {
        const searchText = document.getElementById('search-panels').value.toLowerCase();

        filteredPanels = allPanels.filter(article => {
            const matchesSearch = article.title.toLowerCase().includes(searchText);
            return matchesSearch;
        });

        debugger
        // Sort by publish date (newest first)
        filteredPanels.sort((a, b) => new Date(b.publishDate) - new Date(a.publishDate));

        // Reset to first page when filtering
        currentPage = 1;

        renderPanels();
        renderPaginationButtons();
    }

    // Initialize the page
    document.addEventListener('DOMContentLoaded', () => {
        // Initial fetch
        fetchPanels();

        // Add event listeners for search and filters
        document.getElementById('search-panels').addEventListener('input', filterPanels);
        // document.getElementById('status-filter').addEventListener('change', filterPanels);
        // document.getElementById('category-filter').addEventListener('change', filterPanels);

        // Items per page dropdown
        document.getElementById('items-per-page').addEventListener('change', (e) => {
            itemsPerPage = parseInt(e.target.value);
            currentPage = 1;
            renderPanels();
            renderPaginationButtons();
        });

        // Retry button
        document.getElementById('retry-button').addEventListener('click', fetchPanels);
    });
</script>