    <!-- Editor.js -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/editorjs@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/header@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/underline@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/list@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/embed@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/quote@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/marker@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/delimiter@latest"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/raw@latest"></script>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function () {
            // Tab switching functionality
            const tabButtons = document.querySelectorAll('.tab-button');
            const tabContents = document.querySelectorAll('.tab-content');

            tabButtons.forEach(button => {
                button.addEventListener('click', function () {
                    const targetTab = this.getAttribute('data-tab');

                    // Remove active class from all buttons and contents
                    tabButtons.forEach(btn => btn.classList.remove('active'));
                    tabContents.forEach(content => content.classList.remove('active'));

                    // Add active class to clicked button and target content
                    this.classList.add('active');
                    document.getElementById(targetTab).classList.add('active');
                });
            });

            // Toggle switch functionality
            document.querySelectorAll('.toggle-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function () {
                    const label = this.nextElementSibling;
                    const span = label.querySelector('span');

                    if (this.checked) {
                        span.style.transform = 'translateX(1.5rem)';
                    } else {
                        span.style.transform = 'translateX(0)';
                    }
                });
            });

            // Initialize toggle switches
            document.querySelectorAll('.toggle-checkbox').forEach(checkbox => {
                if (checkbox.checked) {
                    const span = checkbox.nextElementSibling.querySelector('span');
                    span.style.transform = 'translateX(1.5rem)';
                }
            });

            // Email Initialize Editor.js
            editor = new EditorJS({
                holder: 'editorjs',
                tools: {
                    header: {
                        class: Header,
                        config: {
                            placeholder: 'Enter a header',
                            levels: [1, 2, 3, 4],
                            defaultLevel: 2
                        }
                    },
                    List: {
                        class: EditorjsList,
                        inlineToolbar: true,
                        config: {
                            defaultStyle: 'unordered'
                        },
                    },
                    embed: {
                        class: Embed,
                        config: {
                            services: {
                                youtube: true,
                                coub: true
                            }
                        }
                    },
                    quote: {
                        class: Quote,
                        inlineToolbar: true,
                        config: {
                            quotePlaceholder: 'Enter a quote',
                            captionPlaceholder: 'Quote\'s author',
                        },
                    },
                    marker: {
                        class: Marker,
                        shortcut: 'CMD+SHIFT+M',
                    },
                    delimiter: {
                        class: Delimiter,
                    },
                },
                placeholder: 'We offer the best products with excellent customer service and fast shipping...',
                autofocus: true,

            });
            
        });

        // Get DOM elements
        const siteLogoUpload = document.getElementById('site-logo-image-upload');
        const siteFaviconUpload = document.getElementById('site-favicon-image-upload');
        const logoUploadContainer = document.querySelector('#site-logo-image-upload').closest('.image-upload-container');
        const faviconUploadContainer = document.querySelector('#site-favicon-image-upload').closest('.image-upload-container');
        const logoPreview = document.getElementById('logo-image-preview');
        const faviconPreview = document.getElementById('favicon-image-preview');
        const logoPreviewImg = logoPreview.querySelector('img');
        const faviconPreviewImg = faviconPreview.querySelector('img');
        const logoRemoveBtn = logoPreview.querySelector('button');
        const faviconRemoveBtn = faviconPreview.querySelector('button');

        let LOGObase64String;
        let LOGOfileType;
        let LOGOisImageRemoved = false;

        let FAVICONbase64String;
        let FAVICONfileType;
        let FAVICONisImageRemoved = false;

        // File validation function
        function validateFile(file) {
            const validTypes = ['image/svg+xml', 'image/png', 'image/jpeg', 'image/gif'];
            const maxSize = 5 * 1024 * 1024; // 5MB in bytes
            
            if (!validTypes.includes(file.type)) {
                alert('Please select a valid image file (SVG, PNG, JPG, or GIF)');
                return false;
            }
            
            if (file.size > maxSize) {
                alert('File size must be less than 5MB');
                return false;
            }
            
            return true;
        }

        // Handle file selection and preview
        function handleFileSelect(file, previewImg, previewContainer, uploadContainer) {
            if (!validateFile(file)) return;
            
            const reader = new FileReader();
            
            reader.onload = function(e) {
                previewImg.src = e.target.result;
                previewContainer.classList.remove('hidden');
                uploadContainer.classList.add('hidden');
            };
            
            reader.readAsDataURL(file);
        }

        // Remove image and reset uploader
        function removeImage(previewContainer, uploadContainer) {
            previewContainer.classList.add('hidden');
            uploadContainer.classList.remove('hidden');
            
            // Clear the file input
            const fileInput = uploadContainer.querySelector('input[type="file"]');
            fileInput.value = '';
        }

        // Set up drag and drop functionality
        function setupDragAndDrop(uploadContainer, fileInput, previewImg, previewContainer) {
            ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
                uploadContainer.addEventListener(eventName, preventDefaults, false);
            });
            
            function preventDefaults(e) {
                e.preventDefault();
                e.stopPropagation();
            }
            
            ['dragenter', 'dragover'].forEach(eventName => {
                uploadContainer.addEventListener(eventName, highlight, false);
            });
            
            ['dragleave', 'drop'].forEach(eventName => {
                uploadContainer.addEventListener(eventName, unhighlight, false);
            });
            
            function highlight() {
                uploadContainer.classList.add('border-[#3b82f6]', 'bg-blue-50');
            }
            
            function unhighlight() {
                uploadContainer.classList.remove('border-[#3b82f6]', 'bg-blue-50');
            }
            
            uploadContainer.addEventListener('drop', handleDrop, false);
            
            function handleDrop(e) {
                const dt = e.dataTransfer;
                const files = dt.files;
                
                if (files.length) {
                    handleFileSelect(files[0], previewImg, previewContainer, uploadContainer);
                }
            }
        }

        // Event listeners for file inputs
        siteLogoUpload.addEventListener('change', async function(e) {
            if (this.files && this.files[0]) {
                LOGOfileType = (this.files[0].name.split(".")[this.files[0].name.split(".").length - 1]);
                LOGObase64String = await imageFileToBase64(this.files[0]);
                LOGOisImageRemoved = false;
                handleFileSelect(this.files[0], logoPreviewImg, logoPreview, logoUploadContainer);
            }
        });

        siteFaviconUpload.addEventListener('change', async function(e) {
            if (this.files && this.files[0]) {
                FAVICONfileType = (this.files[0].name.split(".")[this.files[0].name.split(".").length - 1]);
                FAVICONbase64String = await imageFileToBase64(this.files[0]);
                FAVICONisImageRemoved = false;
                handleFileSelect(this.files[0], faviconPreviewImg, faviconPreview, faviconUploadContainer);
            }
        });

        // Event listeners for click on upload containers
        logoUploadContainer.addEventListener('click', function() {
            siteLogoUpload.click();
        });

        faviconUploadContainer.addEventListener('click', function() {
            siteFaviconUpload.click();
        });

        // Event listeners for remove buttons
        logoRemoveBtn.addEventListener('click', function(e) {
            debugger
            e.stopPropagation();
            LOGOisImageRemoved = true;
            LOGObase64String = null;
            removeImage(logoPreview, logoUploadContainer);
        });

        faviconRemoveBtn.addEventListener('click', function(e) {
            debugger
            e.stopPropagation();
            FAVICONisImageRemoved = true;
            FAVICONbase64String = null;
            removeImage(faviconPreview, faviconUploadContainer);
        });

        // Converting Image To Base64
        function imageFileToBase64(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
            
                reader.onload = () => {
                    resolve(reader.result);
                };
            
                reader.onerror = (error) => {
                    reject(error);
                };
            
                reader.readAsDataURL(file);
            });
        }
        
        // Initialize drag and drop for both uploaders
        setupDragAndDrop(logoUploadContainer, siteLogoUpload, logoPreviewImg, logoPreview);
        setupDragAndDrop(faviconUploadContainer, siteFaviconUpload, faviconPreviewImg, faviconPreview);
    </script>
</AdminLayout>

<script is:inline define:vars={{
    key:import.meta.env.API_SECURITY_KEY, 
    settingsID :import.meta.env.SITESETTINGSKEY, 
    APIUrl : getAPIPath(), 
    imagePath : getImageBasePath() 
    }}>

    // Function to fetch Setting from API
    async function fetchSettingsData() {
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `siteSettings/` + settingsID, {
                method: "GET",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
            const user = await response.json();
            console.log(user);

            document.getElementById("SiteTitle").value = user.SiteTitle || "";
            document.getElementById("SiteMetaDescription").value = user.siteMetaDescription || "";
            document.getElementById("siteDeployHook").value = user.siteDeployHook || "";
            
            document.getElementById("siteHomePanelCount").value = user.homePanelCount || "";
            document.getElementById("sitePanelCount").value = user.sitePanelCount || "";

            if(user.emailAutoReplyContent){
                document.getElementById("emailFrom").value = user.emailAutoReplyContent.emailFrom || "";
                document.getElementById("emailSubject").value = user.emailAutoReplyContent.emailSubject || "";
                // Email Content in Editor JS
                
                editor.isReady
                .then(() => editor.render({
                    time: Date.now(),
                    blocks: user.emailAutoReplyContent.emailJs_Content || []
                }))
                .catch((err) => console.error("Render failed", err));
            }

            if(user.siteLog){
                logoPreviewImg.src =  imagePath + user.siteLog;
                logoPreview.classList.remove("hidden");
                logoUploadContainer.classList.add("hidden");
            }
            if(user.siteFavicon){
                faviconPreviewImg.src = imagePath +  user.siteFavicon;
                faviconPreview.classList.remove("hidden");
                faviconUploadContainer.classList.add("hidden");
            }

        } catch (error) {
            console.error('Error fetching users:', error);
        }
    }

    // Update User Data
    async function updateSettings(id, data) {
        const obj = Object.fromEntries(data.entries());
        // console.log(obj);
        
        const formDataObj = {
            siteData : {
                SiteTitle : obj.SiteTitle,
                SiteMetaDescription : obj.SiteMetaDescription,
                siteDeployHook : obj.siteDeployHook,
                logoImage : "siteLogo",
                faviconImage : "siteFavicon",
                siteHomePanelCount : parseInt(obj.siteHomePanelCount),
                sitePanelCount : parseInt(obj.sitePanelCount),
            },
            emailData : {
                emailFrom : obj.emailFrom,
                emailJs_Content : JSON.parse(obj.emailJs_Content),
                emailSubject : obj.emailSubject
            },
            MetaData : {
                
            }
        }

        debugger
        if(LOGObase64String){
            formDataObj.MetaData.LOGObase64String = LOGObase64String;
            formDataObj.MetaData.LOGOfileType = LOGOfileType;
        }
        if(FAVICONbase64String){
            formDataObj.MetaData.FAVICONbase64String = FAVICONbase64String;
            formDataObj.MetaData.FAVICONfileType = FAVICONfileType;
        }
        
        if(LOGOisImageRemoved)
            formDataObj.MetaData.LOGOisImageRemoved = LOGOisImageRemoved;
        if(FAVICONisImageRemoved)
            formDataObj.MetaData.FAVICONisImageRemoved = FAVICONisImageRemoved;

        console.log(formDataObj);
        
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `siteSettings/${id}`, {
                method: "PUT",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
                body : JSON.stringify(formDataObj)
            });
            const users = await response.json();
            console.log(users);
            
            debugger
            if (response.ok && response.status === 200) {
                return "success"
            } else {
                return "failed"
            }

        } catch (error) {
            console.error('Error while updating user:', error);
        }
    }

    // Save settings button
    document.getElementById('save-settings').addEventListener('click', async function () {
        const form = document.getElementById('settings-form');
        const formData = new FormData(form);

        await editor.save().then(async (outputData) => {
            formData.append("emailJs_Content", JSON.stringify(outputData.blocks)
                .replaceAll("&nbsp;", " ")
                .replaceAll("  ", " ")
                .replaceAll("  ", " ")
            );
        })

        showLoadingModal()
        let originalText = "";
        setTimeout(() => {
            updateSettings(settingsID , formData).then(resp => {
                if (resp === 'success'){
                    toastSystem.show({
                        type: 'success',
                        title: 'Data updated',
                        message: `Profile information updated successfully`,
                        duration: 6000
                    });
                }
                else{
                    toastSystem.show({
                        type: 'error',
                        title: 'Error occured',
                        message: `An error occured while updating the user`,
                        duration: 6000
                    });
                }

                LOGOisImageRemoved = false;
                FAVICONisImageRemoved = false;
            });
            
            // Show loading state
            originalText = this.innerHTML;
            this.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Saving...';
            this.disabled = true;
            modalSystem.closeAll();
        }, 1500);

         setTimeout(() => {
            this.innerHTML = originalText;
            this.disabled = false;
        }, 1500);
    })

    document.addEventListener('DOMContentLoaded', ()=>{
        fetchSettingsData()
    });
</script>