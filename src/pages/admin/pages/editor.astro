---
import { isAdminLoggedIn } from "../../../data/admin-utils";
import { getAPIPath, getImageBasePath } from "../../../data/utils";
import AdminLayout from "../../../layouts/AdminLayout.astro";

const adminCookie = Astro.cookies.get("admin");

//#region Authentication
if(!isAdminLoggedIn(adminCookie)){
    return Astro.redirect("/admin/login");
}

const response = await fetch(getAPIPath() + `auth/validate`, {
	method: "POST",
    body : JSON.stringify({ userId : adminCookie?.value}),
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
}).then(res => res.json());

// console.log(response);

if(response.status !== 200 && response.isValid !== true){
    return Astro.redirect("/admin/login");
}
//#endregion

---
<style is:inline>
    .ce-header {
        font-weight: 600;
        line-height: 1.4;
    }

    .ce-header h1 {
        font-size: 2.25rem;
    }

    .ce-header h2 {
        font-size: 1.875rem;
    }

    .ce-header h3 {
        font-size: 1.5rem;
    }

    .tag-chip {
        transition: all 0.2s;
    }

    .tag-chip:hover {
        background-color: #3b82f6;
        color: white;
    }

    .image-upload-container {
        transition: all 0.3s;
    }

    .image-upload-container:hover {
        border-color: #3b82f6;
    }

    .editor-container {
        min-height: 400px;
        border: 1px solid #e5e7eb;
        border-radius: 0.5rem;
        padding: 1rem;
    }
</style>
<AdminLayout PageTitle="Page Editor" PageHeader="Page Editor" UserName={response.user.fullname || response.user.username} avatarImagePath={getImageBasePath() + response.user.ProfilePic} emailAdd = {response.user.email}>

    <form id="page-editor-form">
        <!-- Main Content -->
        <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <!-- Left Column - Page Content -->
                <div class="lg:col-span-2 space-y-6">
                    <!-- Title -->
                    <div>
                        <label class="block text-gray-700 text-sm font-medium mb-2" for="pages-title">Page
                            Title</label>
                        <input type="text" id="pageTitle" name="pageTitle"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            placeholder="Enter pages title">
                    </div>
    
                    <!-- Slug -->
                    <div>
                        <label class="block text-gray-700 text-sm font-medium mb-2" for="pageSlug">Slug</label>
                        <input type="text" id="pageSlug" name="pageSlug"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            placeholder="pages-url-slug">
                        <p class="text-gray-500 text-sm mt-1">https://smmpanels.org/<span
                                id="slug-preview">/page/[pages-url-slug]</span></p>
                    </div>
    
                    <!-- Editor.js Container -->
                    <div>
                        <label class="block text-gray-700 text-sm font-medium mb-2">Content</label>
                        <div id="editorjs" class="editor-container"></div>
                    </div>
    
                </div>
    
                <!-- Right Column - Settings -->
                <div class="space-y-6">
                    <div class="flex space-x-3 justify-end">
                        <button class="hidden bg-gray-200 hover:bg-gray-300 text-gray-800 py-2 px-4 rounded-lg flex items-center">
                            <i class="fas fa-eye mr-2"></i> Preview
                        </button>
                        <button class="bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg flex items-center">
                            <i class="fas fa-save mr-2"></i> Save Page
                        </button>
                    </div>
    
                    <!-- Meta Description -->
                    <div class="bg-gray-50 p-4 rounded-lg">
                        <label class="block text-lg font-medium text-gray-900 mb-4" for="PageDescription">Meta
                            Description</label>
                        <textarea id="PageDescription" rows="3" name="PageDescription"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
                            placeholder="Brief description for search engines"></textarea>
                        <p class="text-gray-500 text-sm mt-1">Recommended: 150-160 characters</p>
                    </div>
                </div>
            </div>
        </div>
    </form>

</AdminLayout>
<!-- Editor.js -->
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/editorjs@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/header@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/underline@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/list@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/embed@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/quote@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/marker@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/delimiter@latest"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/@editorjs/raw@latest"></script>

<script is:inline define:vars={{key:import.meta.env.API_SECURITY_KEY, APIUrl : getAPIPath(), imagePath : getImageBasePath()}}>
    let editor;
    let base64String;
    let fileType;
    let isImageRemoved = false;

    document.addEventListener('DOMContentLoaded', function () {
        // Initialize Editor.js
        editor = new EditorJS({
            holder: 'editorjs',
            tools: {
                header: {
                    class: Header,
                    config: {
                        placeholder: 'Enter a header',
                        levels: [1, 2, 3, 4],
                        defaultLevel: 2
                    }
                },
                List: {
                    class: EditorjsList,
                    inlineToolbar: true,
                    config: {
                        defaultStyle: 'unordered'
                    },
                },
                embed: {
                    class: Embed,
                    config: {
                        services: {
                            youtube: true,
                            coub: true
                        }
                    }
                },
                quote: {
                    class: Quote,
                    inlineToolbar: true,
                    config: {
                        quotePlaceholder: 'Enter a quote',
                        captionPlaceholder: 'Quote\'s author',
                    },
                },
                marker: {
                    class: Marker,
                    shortcut: 'CMD+SHIFT+M',
                },
                delimiter: {
                    class: Delimiter,
                },
                raw: {
                    class : RawTool
                },
            },
            placeholder: 'Start writing your Page here...',
            autofocus: true,
            
        });
        
        // Fetching Page Data after 1 second only if User is Editing the Page (using Page ID)
        setTimeout(() => {
            showLoadingModal();
            if(localStorage.getItem("edit-page"))
                fetchPageData(localStorage.getItem("edit-page"));
            modalSystem.closeAll();
        }, 1000);

        // Update slug preview as user types title
        const titleInput = document.getElementById('pageTitle');
        const slugInput = document.getElementById('pageSlug');
        const slugPreview = document.getElementById('slug-preview');

        titleInput.addEventListener('input', function () {
            const title = titleInput.value;
            const slug = title.toLowerCase()
                .replace(/[^\w ]+/g, '')
                .replace(/ +/g, '-');

            slugInput.value = slug;
            slugPreview.textContent = slug;
        });

        slugInput.addEventListener('input', function () {
            slugPreview.textContent = slugInput.value;
        });

        // Save Page functionality
        const form = document.getElementById('page-editor-form');
        form.addEventListener('submit', async function (e) {
            e.preventDefault();

            const formData = new FormData(this);
            if(base64String)
                formData.append("imageBase64", base64String);
            if(fileType)
                formData.append("fileType", fileType);
            if(isImageRemoved)
                formData.append("removeImage", true);
            
            editor.save().then(async (outputData) => {
                // console.log('Page content: ', outputData);
                formData.append("pageContent", JSON.stringify(outputData.blocks)
                    .replaceAll("&nbsp;", " ")
                    .replaceAll("  ", " ")
                    .replaceAll("  ", " ")
                );
                // alert('Page saved successfully!');

                const formDataObj = {};
                formData.forEach((value, key) => (formDataObj[key] = value));
                
                debugger
                console.log(formDataObj);

                showLoadingModal();
                try {
                    let APIPath = APIUrl + "pages/"; 
                    let ReqType = "POST";

                    if(localStorage.getItem("edit-page")){
                        APIPath = APIUrl + `pages/${localStorage.getItem("edit-page")}`;
                        ReqType = "PUT";
                    }

                    const response = await fetch(APIPath, {
                        method: ReqType,
                        headers: {
                            'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key,
                        },
                        body : JSON.stringify(formDataObj),
                    });
            
                    const data = await response.json();
                    console.log("API Response:", data);
            
                    if (response.ok && (response.status === 201 || response.status === 200)) {
                        let msg = `New Page Added successfully.`;
                        if(localStorage.getItem("edit-page"))
                            msg = "Page Updated successfully"
                        toastSystem.show({
                            type: 'success',
                            title: 'Page Saved',
                            message: msg,
                            duration: 6000
                        });
                    }
                    else if(response.status == 500 && data.reason.includes("already exists in table")){
                        toastSystem.show({
                            type: 'error',
                            title: 'Page already exist',
                            message: `The slug you are trying to enter already exist in the database.`,
                            duration: 6000
                        });
                    }
                    else {
                        // alert("Login failed: " + data.message);
                        toastSystem.show({
                            type: 'error',
                            title: 'Error occured',
                            message: `An error occured while saving Page`,
                            duration: 6000
                        });
                    }
                    isImageRemoved = false;
                } catch (error) {
                    // alert("Login failed: " + data.message);
                    toastSystem.show({
                        type: 'error',
                        title: 'Error occured',
                        message: `An error occured while saving Page`,
                        duration: 6000
                    });
                }

                modalSystem.closeAll();
                if(!localStorage.getItem("edit-page")){
                    // imagePreview.querySelector('button').click(); // Click on the remove image button of featured image
                    form.reset();
                    editor.clear();
                }
                
            }).catch((error) => {
                console.log('Saving failed: ', error);
            });
            
        });
    });
    
    async function fetchPageData(pageId){
        try {
            const response = await fetch(APIUrl + `pages/${pageId}`, {
                method: "GET",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
        
            const data = await response.json();
            pageData = data;
            console.log("API Response:", pageData);
        
            if (response.ok && response.status === 200) {
                // Populate the values in the Form Fields
                document.getElementById("pageTitle").value = pageData.pageTitle;
                document.getElementById("pageSlug").value = pageData.pageSlug;
                document.getElementById("PageDescription").value = pageData.PageDescription;
                
                let editorJsContent;
                editorJsContent = {
                    time: Date.now(),
                    blocks: []
                }

                if(Array.isArray(pageData.pageContent)){
                    editorJsContent = {
                        time: Date.now(),
                        blocks: pageData.pageContent
                    }
                }

                // Content in Editor JS
                editor.isReady
                .then(() => editor.render(editorJsContent))
                .catch((err) => console.error("Render failed", err));
                
            } else {
                // alert("Login failed: " + data.message);
                toastSystem.show({
                    type: 'error',
                    title: 'Error occured',
                    message: `An error occured while fetching services`,
                    duration: 6000
                });
            }
        } catch (error) {
            // alert("Login failed: " + data.message);
            console.log(error);
            
            toastSystem.show({
                type: 'error',
                title: 'Error occured',
                message: `An error occured while fetching services`,
                duration: 6000
            });
        }
    }
</script>