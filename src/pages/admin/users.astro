---
import { isAdminLoggedIn } from "../../data/admin-utils";
import { getAPIPath, getImageBasePath } from "../../data/utils";
import AdminLayout from "../../layouts/AdminLayout.astro";


const adminCookie = Astro.cookies.get("admin");

//#region Authentication
if(!isAdminLoggedIn(adminCookie)){
    return Astro.redirect("/admin/login");
}

const response = await fetch(getAPIPath() + `auth/validate`, {
	method: "POST",
    body : JSON.stringify({ userId : adminCookie?.value}),
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
}).then(res => res.json());

// console.log(response);

if(response.status !== 200 && response.isValid !== true){
    return Astro.redirect("/admin/login");
}
//#endregion
---
<AdminLayout PageTitle="Users" PageHeader="Users" UserName={response.user.fullname || response.user.username} avatarImagePath={getImageBasePath() + response.user.ProfilePic} emailAdd = {response.user.email}>
    <!-- Users Page -->
    <div class="page" id="users">
        <div class="bg-white rounded-lg shadow p-6">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-xl font-semibold">User Management</h2>
                <button id="addNewUserBtn" class="hidden bg-blue-600 hover:bg-blue-700 text-white py-2 px-4 rounded-lg flex items-center">
                    <i class="fas fa-plus mr-2"></i> Add User
                </button>
            </div>  

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="users-table-body" class="divide-y divide-gray-200">
                        <!-- Users will be dynamically inserted here -->
                        <tr id="loading-row">
                            <td colspan="5" class="px-4 py-4 text-center">
                                <div class="flex justify-center items-center">
                                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                                    <span class="ml-2 text-gray-600">Loading users...</span>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</AdminLayout>

<script is:inline define:vars={{key:import.meta.env.API_SECURITY_KEY, APIUrl : getAPIPath(), imagePath : getImageBasePath(), userId : adminCookie?.value}}>
    // Function to populate the table with user data
    function populateUserTable(users) {
        const tbody = document.getElementById('users-table-body');
        tbody.innerHTML = "";
        users.forEach(user => {
            const row = document.createElement('tr');

            // Default profile picture if none provided
            const profilePic = user.ProfilePic?.url || '/assets/images/user2.png';

            debugger
            // Determine status based on your business logic
            // You might want to add a status field to your API response
            const status = getStatus(user.isApproved); // You'll need to implement this

            row.innerHTML = `
                <td class="px-4 py-4 whitespace-nowrap">
                    <div class="flex items-center">
                        <div class="flex-shrink-0 h-10 w-10">
                            <img class="h-10 w-10 rounded-full" src="${imagePath + user.picFile}" onerror="this.onerror=null; this.src='${profilePic}';" alt="${user.fullname}">
                        </div>
                        <div class="ml-4">
                            <div class="text-sm font-medium text-gray-900">${user.fullname || "[username_not_set]"}</div>
                            <div class="text-sm text-gray-500">${user.username}</div>
                        </div>
                    </div>
                </td>
                <td class="px-4 py-4 whitespace-nowrap">
                    <div class="text-sm text-gray-900">${user.email}</div>
                </td>
                <td class="px-4 py-4 whitespace-nowrap">
                    <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full ${getStatusClasses(status)}">
                        ${status}
                    </span>
                </td>
                <td class="px-4 py-4 whitespace-nowrap text-sm text-gray-500">${user.role}</td>
                <td class="px-4 py-4 whitespace-nowrap text-sm font-medium">
                    ${
                        (userId === user._id) 
                        ? `<button title="You cannot remove yourself right now. But somebody else can. Haha 😉" disabled class="delete-user-btn disabled:hover:text-white text-red-600 hover:text-red-900" data-id=${user._id}>Delete</button>`
                        : `<button class="delete-user-btn text-red-600 hover:text-red-900" data-id=${user._id}>Delete</button>`
                    }
                    ${
                        (user.isApproved == false || user.isApproved == null)
                        ? `<button class="ml-5 approveBtn text-green-600 hover:text-red-900" data-id=${user._id}>Approve</button>`
                        : ""
                    }
                </td>
            `;
            
            tbody.appendChild(row);
        });
    }   

    // Helper function to determine status classes
    function getStatusClasses(status) {
        const statusClasses = {
            'Active': 'bg-green-100 text-green-800',
            'Pending': 'bg-yellow-100 text-yellow-800',
            'Inactive': 'bg-red-100 text-red-800'
        };
        return statusClasses[status] || 'bg-gray-100 text-gray-800';
    }   

    // Helper function to determine user status (you'll need to customize this)
    function getStatus(userStatus) {
        // This is a placeholder - implement your own logic based on your data
        // You might want to add a status field to your API response
        if(userStatus)
            return 'Active'; // Default to Active for now
        else
            return 'Pending';
    }   

    // Function to fetch users from API
    async function fetchUsers() {
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `users`, {
                method: "GET",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
            const users = await response.json();
            console.log(users);
            
            // Clear loading row
            const loadingRow = document.getElementById('loading-row');
            if (loadingRow) {
                loadingRow.remove();
            }
            
            // Populate table with user data
            populateUserTable(users);
            // Delete user function
            document.querySelectorAll(".delete-user-btn").forEach(deleteBtn => {
                deleteBtn.addEventListener("click", ()=>{
                    debugger
                    // Show Delete modal if Yes proceed else return
                    showDeleteModal().then(resp => {
                        if (resp === 'Delete Clicked') {
                            // Perform delete operation
                            deleteUsers(deleteBtn.dataset.id);
                            console.log('Deleting item...');
                        }
                    });
                })
            });
            
            document.querySelectorAll(".approveBtn").forEach(approveBtn => {
                approveBtn.addEventListener("click", ()=>{
                    // Show Delete modal if Yes proceed else return
                    showConfirmationModal().then(resp => {
                        if (resp === 'Confirm Clicked') {
                            approveUser(approveBtn.dataset.id);
                            // Perform delete operation
                            console.log('Approving item...');
                        }
                    });
                })
            });

        } catch (error) {
            console.error('Error fetching users:', error);
            document.getElementById('loading-row').innerHTML = `
                <td colspan="5" class="px-4 py-4 text-center text-red-600">
                    Error loading users. Please try again.
                </td>
            `;
        }
    } 

    // Create User
    async function createUsers(data) {
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `users`, {
                method: "POST",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
                body : data
            });
            const users = await response.json();
            console.log(users);
            
            if (response.ok && response.status === 200) {
                toastSystem.show({
                    type: 'success',
                    title: 'User Creation',
                    message: `User Created successfully`,
                    duration: 6000
                });
                fetchUsers();
            } else {
                // alert("Login failed: " + data.message);
                toastSystem.show({
                    type: 'error',
                    title: 'Error occured',
                    message: `An error occured while creating the user`,
                    duration: 6000
                });
            }

        } catch (error) {
            console.error('Error fetching users:', error);
            document.getElementById('loading-row').innerHTML = `
                <td colspan="5" class="px-4 py-4 text-center text-red-600">
                    Error loading users. Please try again.
                </td>
            `;
        }
    } 

    // Delete User
    async function deleteUsers(id) {
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `users/${id}`, {
                method: "DELETE",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
            const users = await response.json();
            console.log(users);
            
            if (response.ok && response.status === 200) {
                toastSystem.show({
                    type: 'success',
                    title: 'Data Deleted',
                    message: `User deleted successfully`,
                    duration: 6000
                });
                fetchUsers();
            } else {
                // alert("Login failed: " + data.message);
                toastSystem.show({
                    type: 'error',
                    title: 'Error occured',
                    message: `An error occured while deleting the user`,
                    duration: 6000
                });
            }

        } catch (error) {
            console.error('Error fetching users:', error);
            document.getElementById('loading-row').innerHTML = `
                <td colspan="5" class="px-4 py-4 text-center text-red-600">
                    Error loading users. Please try again.
                </td>
            `;
        }
    }  

    document.querySelector("#addNewUserBtn").addEventListener("click", ()=>{
        let UserModalDataConfiguration = {
            title: 'Create New User',
            content: `
            <form id="item-form">
                <div class="space-y-4">
                    <div class="input-group">
                        <label class="input-label">Full Name</label>
                        <input type="Text" id='userFullName' name='userFullName' class="input-field" placeholder="John Doe">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Email</label>
                        <input type="email" id='userEmailAddress' name='userEmailAddress' class="input-field" placeholder="john@example.com">
                    </div>
                    <div class="input-group">
                        <label class="input-label">Role</label>
                        <select class="input-field" id="userRole" name="userRole">
                            <option>Select</option>
                            <option>User</option>
                            <option>Admin</option>
                        </select>
                    </div>
                </div>
            </form>
            `
        }

        showFormModal(UserModalDataConfiguration).then(resp => {
            if (resp === 'Submit Clicked') {
                const form = document.getElementById('item-form');
                const formData = new FormData(form);
                
                const username = formData.get("userFullName");
                const email = formData.get("userEmailAddress");
                const role = formData.get("userRole");

                // If Form is not Valid
                let errors = [];
                if (!username || username.length < 3) {
                  errors.push("Username must be at least 3 characters long.");
                }

                const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailPattern.test(email)) {
                  errors.push("Invalid email address.");
                }
                
                if (role == "Select") {
                  errors.push("Role not selected");
                }

                if (errors.length > 0) {
                    toastSystem.show({
                        type: 'error',
                        title: 'Empty Fields',
                        message: `Required Fields are not provided`,
                        duration: 6000
                    });
                    alert("Required Fields - " + errors )
                    // console.log("Validation failed:", errors);
                } else {

                    // Perform creation operation
                    createUsers(formData)
                    
                  console.log("Validation passed!");
                }
            }
        }); 
    })

    // Approve an User
    async function approveUser(id) {
        debugger
        try {
            // Replace with your actual API endpoint
            const response = await fetch(APIUrl + `users/${id}`, {
                method: "PATCH",
                headers: {
                    'Content-Type': 'application/json',
                    "origin" : "http://localhost:4321",
                    // "x-api-key" : key
                },
            });
            const users = await response.json();
            console.log(users);
            
            if (response.ok && response.status === 200) {
                toastSystem.show({
                    type: 'success',
                    title: 'Data Deleted',
                    message: `User deleted successfully`,
                    duration: 6000
                });
                fetchUsers();
            } else {
                // alert("Login failed: " + data.message);
                toastSystem.show({
                    type: 'error',
                    title: 'Error occured',
                    message: `An error occured while deleting the user`,
                    duration: 6000
                });
            }

        } catch (error) {
            console.error('Error fetching users:', error);
            document.getElementById('loading-row').innerHTML = `
                <td colspan="5" class="px-4 py-4 text-center text-red-600">
                    Error loading users. Please try again.
                </td>
            `;
        }
    }
    
    // Fetch users when the page loads
    document.addEventListener('DOMContentLoaded', fetchUsers);
</script>
