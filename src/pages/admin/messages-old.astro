        // DOM Elements
        const contactsList = document.getElementById('contacts-list');
        const contactsEmpty = document.getElementById('contacts-empty');
        const messageHeader = document.getElementById('message-header');
        const messagesContainer = document.getElementById('messages-container');
        const messageEmpty = document.getElementById('message-empty');
        const unreadCount = document.getElementById('unread-count');

        let selectedContactId = null;

        // Render contacts list
        function renderContacts() {
            contactsList.innerHTML = '';

            if (contacts.length === 0) {
                contactsEmpty.classList.remove('hidden');
                return;
            }

            contactsEmpty.classList.add('hidden');

            contacts.forEach(contact => {
                const contactElement = createContactElement(contact);
                contactsList.appendChild(contactElement);
            });

            updateUnreadCount();
        }

        // Create contact element
        function createContactElement(contact) {
            const div = document.createElement('div');
            div.className = `contact-item p-4 ${contact.unread > 0 ? 'unread' : ''} ${selectedContactId === contact.id ? 'active' : ''}`;
            div.setAttribute('data-contact-id', contact.id);

            div.innerHTML = `
                <div class="flex items-center space-x-3">
                    <div class="relative">
                        <img class="w-12 h-12 rounded-full" src="${contact.avatar}" alt="${contact.name}">
                        <span class="status-dot ${contact.status} absolute bottom-0 right-0 border-2 border-white"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between">
                            <h3 class="contact-name font-medium text-gray-900 truncate">${contact.name}</h3>
                            <span class="contact-time text-xs text-gray-500">${contact.lastMessageTime}</span>
                        </div>
                        <p class="contact-preview text-sm text-gray-600 truncate mt-1">${contact.lastMessage}</p>
                        ${contact.unread > 0 ? `
                            <div class="flex items-center justify-between mt-1">
                                <span class="text-xs text-blue-600 font-medium">${contact.unread} unread</span>
                            </div>
                        ` : ''}
                    </div>
                </div>
            `;

            div.addEventListener('click', () => selectContact(contact.id));
            return div;
        }

        // Select contact
        function selectContact(contactId) {
            selectedContactId = contactId;
            const contact = contacts.find(c => c.id === contactId);

            if (!contact) return;

            // Update contacts list active state
            document.querySelectorAll('.contact-item').forEach(item => {
                item.classList.remove('active');
            });
            document.querySelector(`[data-contact-id="${contactId}"]`).classList.add('active');

            // Show message view
            showMessageView(contact);

            // Mark messages as read
            if (contact.unread > 0) {
                contact.messages.forEach(message => {
                    message.read = true;
                });
                contact.unread = 0;
                renderContacts();
            }
        }

        // Show message view
        function showMessageView(contact) {
            messageEmpty.classList.add('hidden');
            messageHeader.classList.remove('hidden');
            messagesContainer.innerHTML = '';

            // Update header
            document.getElementById('contact-avatar').src = contact.avatar;
            document.getElementById('contact-name').textContent = contact.name;
            document.getElementById('contact-status').className = `status-dot ${contact.status}`;
            document.getElementById('contact-status-text').textContent = getStatusText(contact.status, contact.lastSeen);

            // Render messages
            contact.messages.forEach(message => {
                const messageElement = createMessageElement(message);
                messagesContainer.appendChild(messageElement);
            });

            // Scroll to bottom
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            // Update button events
            updateButtonEvents(contact.id);
        }

        // Create message element
        function createMessageElement(message) {
            const div = document.createElement('div');
            div.className = `message-bubble rounded-lg p-3 ${message.type === 'sent' ? 'sent' : 'received'}`;

            div.innerHTML = `
                <div class="text-sm">${message.content}</div>
                <div class="text-xs opacity-70 mt-1 text-right">${message.time}</div>
            `;

            return div;
        }

        // Get status text
        function getStatusText(status, lastSeen) {
            switch (status) {
                case 'online': return 'Online';
                case 'away': return `Away - Last seen ${lastSeen}`;
                case 'offline': return `Offline - Last seen ${lastSeen}`;
                default: return '';
            }
        }

        // Update button events
        function updateButtonEvents(contactId) {
            const contact = contacts.find(c => c.id === contactId);
            if (!contact) return;

            // Mark as read
            document.getElementById('mark-read').onclick = () => {
                contact.messages.forEach(message => {
                    message.read = true;
                });
                contact.unread = 0;
                renderContacts();
            };

            // Mark as unread
            document.getElementById('mark-unread').onclick = () => {
                contact.messages.forEach(message => {
                    message.read = false;
                });
                contact.unread = contact.messages.length;
                renderContacts();
            };

            // Delete conversation
            document.getElementById('delete-conversation').onclick = () => {
                if (confirm('Are you sure you want to delete this conversation? This action cannot be undone.')) {
                    const index = contacts.findIndex(c => c.id === contactId);
                    if (index !== -1) {
                        contacts.splice(index, 1);
                        selectedContactId = null;
                        renderContacts();
                        showEmptyMessageState();
                    }
                }
            };
        }

        // Show empty message state
        function showEmptyMessageState() {
            messageHeader.classList.add('hidden');
            messagesContainer.innerHTML = '';
            messageEmpty.classList.remove('hidden');
        }

        // Update unread count
        function updateUnreadCount() {
            const totalUnread = contacts.reduce((sum, contact) => sum + contact.unread, 0);
            unreadCount.textContent = totalUnread;
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', function () {
            renderContacts();

            // Add some sample interactions
            setTimeout(() => {
                if (contacts.length > 0) {
                    selectContact(contacts[0].id);
                }
            }, 100);
        });
    </script>
</AdminLayout>