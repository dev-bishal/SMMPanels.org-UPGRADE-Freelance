---
import Dashboard from "../../admin-components/Dashboard.astro";
import { isAdminLoggedIn } from "../../data/admin-utils";
import { getAPIPath, getImageBasePath } from "../../data/utils";
import AdminLayout from "../../layouts/AdminLayout.astro";

const adminCookie = Astro.cookies.get("admin");
const key = import.meta.env.API_SECURITY_KEY;

//#region Authentication
if(!isAdminLoggedIn(adminCookie)){
    return Astro.redirect("/admin/login");
}

const response = await fetch(getAPIPath() + `auth/validate`, {
	method: "POST",
    body : JSON.stringify({ userId : adminCookie?.value}),
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
}).then(res => res.json());

// console.log(response);

if(response.status !== 200 && response.isValid !== true){
    return Astro.redirect("/admin/login");
}
//#endregion

let PanelData :any[] = [];
let PageData : any[] = [];
let ServiceData : any[] = [];
let MessageData : any[] = [];

//#region Fetch panels from API
const panelFetchresponse = await fetch(getAPIPath() + `panels`, {
    method: "GET",
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
});
PanelData = await panelFetchresponse.json();
//#endregion

//#region Fetch pages from API
const pageFetchresponse = await fetch(getAPIPath() + `pages`, {
    method: "GET",
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
});

PageData = await pageFetchresponse.json();
//#endregion

//#region Fetching Services Request
const servicesFetchresponse = await fetch(getAPIPath() + `services`, {
    method: "GET",
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
});
ServiceData = await servicesFetchresponse.json();
//#endregion

//#region Fetch messages from API
const msgFetchResponse = await fetch(getAPIPath() + `messages`, {
    method: "GET", 
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : import.meta.env.API_SECURITY_KEY
    }
});
MessageData = await msgFetchResponse.json();
//#endregion

const PaymentData = await fetch(getAPIPath() + "payments", {
    method: "GET",
    headers : {
        'Content-Type': 'application/json',
        "origin" : "http://localhost:4321",
        "x-api-key" : key
    }
}).then(Response => Response.json())
        
---
<AdminLayout PageTitle="Home" PageHeader="Dashboard" UserName={response.user.fullname || response.user.username} avatarImagePath={getImageBasePath() + response.user.ProfilePic} emailAdd = {response.user.email}>
	<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js"></script>

	<Dashboard UserName={response.user.fullname || response.user.username} {PanelData} {PageData} {ServiceData} {MessageData} {PaymentData}/>

</AdminLayout>

<script is:inline define:vars={{username : response.user.fullname || response.user.username}}>
	// Auto-show welcome notification
    document.addEventListener('DOMContentLoaded', function () {
        setTimeout(() => {
            toastSystem.show({
                type: 'info',
                title: 'Welcome to Dashboard',
                message: `Hello ${username}. What are you up to today?`,
                duration: 6000
            });
        }, 1000);
    });
</script>

