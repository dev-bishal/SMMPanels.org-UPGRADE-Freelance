<script is:inline define:vars={{currentPanel : slug, imagePath : getImageBasePath(), allPanelsFetch : allPanelsData2, text12 : contentPath?.text[12], text14 : contentPath?.text[14] }}>

    let langDirectory = window.localStorage.getItem("lang") != "en" ? "/" + window.localStorage.getItem("lang") : "";
    let otherPanelsMain = document.querySelector(".others-related-panels");
    let otherPanelsHolder = document.getElementById("otherPanelsHolder");
    function shuffle(array) {
        let currentIndex = array.length;  

        // While there remain elements to shuffle...
        while (currentIndex !== 0) {
            // Pick a remaining element...
            let randomIndex = Math.floor(Math.random() * currentIndex);
            currentIndex--; 
            
            // Swap it with the current element.
            [array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];
        } 

        return array;
    }

    (function() {
        let filteredPanels = allPanelsFetch.filter(obj => obj.panelSlug !== currentPanel);
        filteredPanels = shuffle(filteredPanels);

        if(filteredPanels.length > 0){
            otherPanelsMain.classList.toggle("hidden");
            otherPanelsHolder.innerHTML = "";
            
            filteredPanels.slice(0,3).map((panels) =>(
                otherPanelsHolder.insertAdjacentHTML("afterbegin", 
                    `<a href="${langDirectory}/panels/${panels.panelSlug}" class="other-panel card group rounded-xl relative lg:w-[32%] overflow-hidden">
                        <img src="${imagePath + panels.panelFeaturedImage}" alt={panelTitle} class="size-full lg:h-[230px] rounded-xl">
                        <div class="overlay transition-all ease duration-300 absolute z-0 top-0 group-hover:backdrop-blur-lg left-0 size-full rounded-xl group-hover:bg-[#0000004a] flex items-center justify-center"></div>
                        <span class="text transition-all ease duration-300 absolute z-[1] bottom-4 w-full px-2 translate-y-8 group-hover:translate-y-0">
                            <span class="text-xl font-semibold [text-shadow:_1px_2px_2px_rgb(0_0_0_/_70%)] text-[#9bdd75]">${panels.panelTitle}</span>
                            <span class="flex w-full justify-between text-sm">
                                <span>
                                    <span><i class="fa-duotone fa-solid fa-stars"></i> ${text12}: </span>
                                    <span>${panels.rating + " " + text14}</span>
                                </span>
                            </span>
                        </span>
                    </a>`
                )
                
            ))
        }
        
    })();

</script>