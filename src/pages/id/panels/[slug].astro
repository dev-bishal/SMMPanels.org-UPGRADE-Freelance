                    <h1 class="text-4xl font-bold">{panel.panelTitle}</h1>
            
                    <span class="flex gap-3 justify-center items-center">
                        <a target="_blank" class="block text-xs md:text-base rounded-full p-3 hover:bg-[#69b63d] bg-[#9bdd75] text-black" href={panel.panelWebsiteURL}><i class="fa-regular fa-arrow-up-right-from-square"></i> {metaDataId.text[20]} {panel.panelTitle}</a>
                        <a target="_blank" class="block text-xs md:text-base rounded-full p-3 hover:bg-[#69b63d] bg-[#9bdd75] text-black" href=`/${metaDataId.language}/panels/`><i class="fa-sharp-duotone transform -scale-x-100 fa-light fa-share"></i> {metaDataId.text[19]}</a>
                    </span>
                    <span class="flex justify-center flex-wrap w-full gap-2">
                        <section class="relative flex justify-center gap-2 items-center bg-cover bg-center bg-no-repeat py-2 w-[45%]">
                            <div class="brightnessLow-overlay absolute z-0 rounded-lg w-full h-full bg-[#444444d6] border border-[#9bdd75]"></div>
                            <span class="relative flex items-center justify-center">
                                <i class="text-3xl text-[#9bdd75] fa-regular fa-star-christmas"></i>
                                <span class="absolute size-4 rounded-full shadow-lg shadow-[#9bdd75]"></span>
                            </span>
                            <h2 class="z-[1] text-center">
                                <span class="text-3xl font-semibold block"> {servicesResponse.length} </span>
                                <span class="text-xs">{metaDataId.text[21]}</span>
                            </h2>
                        </section>
                        <section class="relative flex justify-center gap-2 items-center bg-cover bg-center bg-no-repeat py-2 w-[45%]">
                            <div class="brightnessLow-overlay absolute z-0 rounded-lg w-full h-full bg-[#444444d6] border border-[#9bdd75]"></div>
                            <span class="relative flex items-center justify-center">
                                <i class="text-3xl text-[#9bdd75] fa-solid fa-badge-dollar"></i>
                                <span class="absolute size-4 rounded-full shadow-lg shadow-[#9bdd75]"></span>
                            </span>
                            <h2 class="z-[1] text-center"> <span class="text-3xl font-semibold block">
                                    ${averagePrice} </span>
                                <span class="text-xs">{metaDataId.text[22]}</span>
                            </h2>
                        </section>
                        <section class="relative flex justify-center gap-2 items-center bg-cover bg-center bg-no-repeat py-2 w-[45%]">
                            <div class="brightnessLow-overlay absolute z-0 rounded-lg w-full h-full bg-[#444444d6] border border-[#9bdd75]"></div>
                            <span class="relative flex items-center justify-center">
                                <i class="text-3xl text-[#9bdd75] fa-duotone fa-solid fa-stars"></i>
                                <span class="absolute size-4 rounded-full shadow-lg shadow-[#9bdd75]"></span>
                            </span>
                            <h2 class="z-[1] text-center"> <span class="text-3xl font-semibold block">
                                    {panel.rating} </span>
                                <span class="text-xs">{metaDataId.text[12]}</span>
                            </h2>
                        </section>
                        <section class="relative flex justify-center gap-2 items-center bg-cover bg-center bg-no-repeat py-2 w-[45%]">
                            <div class="brightnessLow-overlay absolute z-0 rounded-lg w-full h-full bg-[#444444d6] border border-[#9bdd75]"></div>
                            <span class="relative flex items-center justify-center">
                                <i class="text-3xl text-[#9bdd75] fa-duotone fa-solid fa-credit-card"></i>
                                <span class="absolute size-4 rounded-full shadow-lg shadow-[#9bdd75]"></span>
                            </span>
                            <h2 class="z-[1] text-center"> <span class="text-3xl font-semibold block">
                                    {panel.paymentOptions.length} </span>
                                <span class="text-xs">{metaDataId.text[7]}</span>
                            </h2>
                        </section>
                    </span>
                </span>

                <span class="w-full relative lg:w-1/2 mt-10 flex justify-center items-center flex-col gap-2">
                    <img src={getImageBasePath() + panel.panelFeaturedImage} alt={panel.panelTitle +" Panel Image"} class="shadow-lg rounded-lg w-[110%] lg:w-full lg:h-[280px] z-[1]" height="280px" width="100%">
                    <span class="bg-design bg-[#66a044] rounded-2xl lg:h-[290px] h-[220px] lg:w-[105%] w-[90%] lg:-translate-y-6 absolute z-0"></span>
                </span>
            </div>

        </div>

        <section class="services p-6 bg-[#d3d3d3] dark:bg-[#202123] rounded-lg my-5">
            <span class="flex justify-between items-center w-full mb-5">
                <h2 class="text-2xl font-semibold"><i class="fa-duotone fa-solid fa-rocket"></i> {metaDataId.text[24]}</h2>
                <span id="serviceSeeAllBtn" class="text-[#9bdd75] text-sm cursor-pointer w-[30%] md:w-fit">{metaDataId.text[8]} <i class="fa-light fa-angle-down transition-all ease-in-out"></i></span>
            </span>
            
            <div class="matching-services flex gap-2 flex-wrap justify-center items-center flex-1 mb-3">
                {
                    randomPlatformList.map((platform:any, index: number)=>(
                    <div class="service-card flex justify-center items-center gap-2 lg:w-[19%] w-[45%] rounded-md p-2 bg-[#45454549] hover:bg-[#45454596]"
