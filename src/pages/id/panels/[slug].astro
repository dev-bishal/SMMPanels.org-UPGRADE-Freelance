---
import { isSame, getAPIPath, JsonToHtml, getRandomElements, optimizeImageUrl, shuffleArray, mainData, AIPrompt, getImageBasePath } from "../../../data/utils";
import MainLayout from "../../../layouts/MainLayout.astro";
import sitejabberLogo from "../../../assets/Sitejabber_logo.png"
import reviewsLogo from "../../../assets/reviewsLogo.webp"
import trustpilotlogo from "../../../assets/trustpilotlogo.webp"

import { makeWordsClickable, getLanguage } from "../../../data/utils";
import { metaDataId } from "../data";
let contentPath = metaDataId;

interface panelSchema {
    id: string;
    panelFeaturedImage: string;
    panelAPIKey: string;
    panelAPILink: string;
    panelTitle: string;
    panelWebsiteURL: string;
    panelSlug: string;
    panelTextDescription: string;
    panelMetaDesc: string;
    panelTotalServices: number;
    rating: number;
    ratingOtherSites: [{
        score : string,
        ratingURL :string,
        ratingSite :string,
        TotalReviews : string
    }];
    paymentOptions: [{
        payDepo: string;
        payOption: string;
    }],
    dataType : string
}

var APIError = "";

const allServicesFetch = await fetch(getAPIPath() + "services");
const allServices = await allServicesFetch.json();

let allPanelsData2: panelSchema[] = await fetch(getAPIPath() + "panels").then(Response => Response.json());
allPanelsData2 = shuffleArray(allPanelsData2);

//#region fetching Panels and getting the current panel as Static Path
export const prerender = true;
export async function getStaticPaths() {
    const allPanelsFetch: any = await fetch(getAPIPath() + "panels");
    const allPanelRes: panelSchema[] = await allPanelsFetch.json();

    return allPanelRes.map((panel: any) => ({
        params: { slug: panel.panelSlug },
        props: { panel },
    }));
}
const { panel } = Astro.props;
const { slug } = Astro.params;
//#endregion

//#region Fetching the current panel Services list and calculating the Average Price from its API
var servicesResponse : any;
var averagePrice: number = 0,totalPrice : number = 0;
try {
    servicesResponse = await fetch(
        `${panel.panelAPILink}?key=${panel.panelAPIKey}&action=services`
    ).then(Response => Response.json());

    try {
        if(servicesResponse.error.toLowerCase().includes("invalid")){
            APIError = servicesResponse.error;
            servicesResponse = [];
        }
    } catch (error) {}
    
} catch (error) { 
    console.log(panel.panelTitle, `${panel.panelAPILink}?key=${panel.panelAPIKey}&action=services` + "- Could not Find Services with GET Method");
    servicesResponse = [];
}

for (let j = 0; j < servicesResponse.length; j++) {
    if((Number(servicesResponse[j].rate) < 850) && (Number(servicesResponse[j].rate) > 0.0001))
        totalPrice += Number(servicesResponse[j].rate);
}
if(servicesResponse.length != 0)
    averagePrice= Number((totalPrice/servicesResponse.length).toFixed(2));
//#endregion

//#region Finding the Related Services from the current panel
var randomPlatformList: any = [];
let allServiceNames: string[] = [];
var platformList: any = [];

if(servicesResponse.length != undefined){
    if(servicesResponse.length != 0) {
        
        // Collecting Services names which are available in the Panels API Services
        servicesResponse.map((service: any) =>
            allServiceNames.push(service.name.toLowerCase()),
        );
        
        for (let i = 0; i < allServices.length; i++) {
            for (let j = 0; j < allServiceNames.length; j++) {
                if (isSame(allServiceNames[j], allServices[i].serviceTitle)) {
                    if (platformList.includes(allServices[i]) == false)
                        platformList.push(allServices[i]);
                }
            }
        }
        randomPlatformList = getRandomElements(platformList, platformList.length)
    }
    else
        servicesResponse = [];    
}
else
    servicesResponse = [];    
//#endregion 

//#region Forming Rating Collection for the current panel
var ratingCollection: String[] = [];
for (let j = 0; j < 5; j++) {
    if (j < panel.rating) ratingCollection.push("fa-sharp fa-solid fa-star-sharp");
    else ratingCollection.push("fa-sharp fa-regular fa-star-sharp");
}
//#endregion

const allPaymentOptions: any = await fetch(getAPIPath() + "payments").then(Response => Response.json());
function getPaymentOptImgLink(paymentOpTitle:string) {
    for (let i = 0; i < allPaymentOptions.length; i++) {
        if(allPaymentOptions[i].paymentOptTitle.toLowerCase() === paymentOpTitle.toLowerCase())
        return allPaymentOptions[i];
    }
}

var platformListTitles: any = [];
allServices.map((services:any)=>(
    platformListTitles.push(services.serviceTitle.toLowerCase())
));

let targetLanguage = getLanguage(metaDataId.language);

let originalData = new FormData();
let command1 = `You are a Human friendly translator Assistant. Translate the following text in ${targetLanguage}.`;
let command2 = `You are a Human friendly translator Assistant. The submitted Text is a HTML Code, so only translate the text inside the tags. Return the translated text with orginal tags. Your Target language is ${targetLanguage}. Note- Don't translate the anchor tags, let them be in ENGLISH.`;


originalData.append("command1", command1);
originalData.append("originalData1", panel.panelMetaDesc);

// let data = await AIPrompt(command2, makeWordsClickable(JsonToHtml(panel.panelTextDescription), platformListTitles, `/${metaDataId.language}/services/`) )



const allSiteFetch:any = await fetch(getAPIPath() + "siteSettings/" + import.meta.env.SITESETTINGSKEY).then(Response => Response.json());
---

<MainLayout 
    siteTitle = {allSiteFetch.SiteTitle} 
    lang={metaDataId.language}
    title={panel.panelTitle + " | Ulasan & Layanan"} 
    metaDescription={panel.panelMetaDescriptionID} 
    pageFeaturedImage={getImageBasePath() + panel.panelFeaturedImage}
    pageType="article">
    
    <article class="my-5 text-[#202123] dark:text-white" >
        
        <div class="head-section relative">
            <div class="cover relative size-full min-h-[650px] lg:min-h-[auto] z-0">
                <img src={getImageBasePath() + panel.panelFeaturedImage} class="w-full md:h-[830px] lg:h-[400px] h-full rounded-lg" alt={panel.panelTitle} />
                <div class="overlay absolute backdrop-blur-md top-0 left-0 w-full h-full bg-radial-light dark:bg-radial bg-opacity-80"></div>
            </div>

            <div class="heading-section lg:p-6 p-3 z-[1] absolute top-0 text-white size-full flex flex-col lg:flex-row gap-8">
