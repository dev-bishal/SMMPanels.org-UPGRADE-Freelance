        </section>

        <div class="content-box my-4">
            <p>{panel.panelMetaDescriptionID}</p>
        </div>

        <div class="split w-full gap-4 flex flex-col lg:flex-row">
            <section class="rounded-lg shadow-md bg-[#d3d3d3] dark:bg-[#202123] lg:w-1/2 w-full flex justify-center items-center bg-cover bg-center bg-no-repeat mb-4">
                <div class="paymentOptions z-[1] w-full p-3 rounded-md ">
                    <h2 class="text-3xl font-semibold">{metaDataId.text[7]}</h2>
                    <div class="table w-full mt-4">
                        <div class="header flex w-full p-2 gap-x-2 font-semibold bg-[#44444469] rounded-sm">
                            <div class="col w-[40%]">{metaDataId.text[51]}</div>
                            <div class="col w-[25%]">{metaDataId.text[52]}</div>
                            <div class="col w-[25%]">{metaDataId.text[53]}</div>
                        </div>
                        {
                            panel.paymentOptions.map((paymentOp: any) => (
                                <div class="row flex w-full p-2 gap-x-2">
                                    <div class="col w-[40%] flex gap-2">
                                        {
                                            (getPaymentOptImgLink(paymentOp.payOption) != undefined || getPaymentOptImgLink(paymentOp.payOption) != null) &&
                                            <a href={`/${metaDataId.language}/payment-options/`+paymentOp.payOption.toLowerCase().replaceAll(" ", "-").replaceAll("/", "-")}>
                                                <img height="30px" src={getImageBasePath() + getPaymentOptImgLink(paymentOp.payOption).paymentLogo} class="h-[30px] object-contain hover:scale-105 max-w-[50px]" alt={paymentOp.payOption} />
                                            </a>
                                        }
                                        {paymentOp.payOption}
                                    </div>
                                    <div class="col w-[25%]">
                                        {paymentOp.payDepo}
                                    </div>
                                    <div class="col w-[25%]">
                                        {paymentOp.payBonus || "-"}
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </section>
        
            <section class="rounded-lg bg-[#d3d3d3] dark:bg-[#202123] lg:w-1/2 w-full h-auto flex justify-center items-start bg-cover bg-center bg-no-repeat mb-4">
                <div class="ratings z-[1] w-full p-3 rounded-md shadow-md h-full">
                    <h2 class="text-3xl font-semibold">{metaDataId.text[13]}</h2>

                    <div class="rating flex gap-5 w-full flex-col justify-center items-stretch h-full">
                        <span class="main-ratings flex items-center flex-col gap-2">
                            <span class="text-5xl font-semibold">{panel.rating}</span>
                            <span class="flex gap-2 text-[#9bdd75] text-2xl">
                                {
                                    ratingCollection.map((rating) => (
                                        <i class={rating.toString()} />
                                    ))
                                }
                            </span>
                        </span>

                        {
                            (panel.ratingOtherSites != null )  &&
                            panel.ratingOtherSites.map((rating:any)=>(
                                rating.ratingURL != "" &&
                                (
                                    <a target="_blank"href={rating.ratingURL} class="reviewsBox text-[#0056b3] text-center w-full mb-4 flex flex-col items-center bg-[#c3d6b8] p-2 rounded-md shadow-md">
                                        <img src={
                                            (rating.ratingSite == "TrustPilot" ? trustpilotlogo.src
                                            :
                                            rating.ratingSite == "Sitejabber" ? sitejabberLogo.src
                                            :
                                            reviewsLogo.src)
                                        } alt={rating.ratingSite + " logo"} class="h-10 lg:w-[180px] w-full object-contain" />
                                        <span class="flex gap-2 font-bold text-2xl">
                                            {
                                                `${rating.score} / 5` 
                                            }
                                        </span>
                                        <span class="block">{ `(${rating.TotalReviews} Reviews)` }</span>
                                    </a>
                                )
                            ))
                        }

                    </div>
                </div>
            </section>
        </div>

        <div class="content p-6 bg-[#d3d3d3] dark:bg-[#202123] rounded-lg my-5" set:html={makeWordsClickable(panel.panelTextDescriptionID || "", platformListTitles)}></div>

        <div class="services-list my-4">
            {
                servicesResponse.length != 0 && (
                    <h2 class="text-3xl font-semibold">
                        {metaDataId.text[25]} {panel.panelTitle}
                    </h2>
                    <div class="services-table-holder shadow-2xl mb-4 mt-5 lg:w-full w-[89vw] overflow-auto">
                        <div class="table-wrapper md:w-full w-[700px] bg-[#d3d3d3] dark:bg-transparent ">
                            <span class="offerHeader w-full flex bg-[#629645] font-semibold text-white ">
                                <span class="offer_id my-6 w-[5%] pl-2">
                                    {metaDataId.text[46]}
                                </span>
                                <span class="offer_service my-6 w-[41%]">
                                    {metaDataId.text[47]}
                                </span>
                                <span class="offer_Minorder my-6 w-[18%]">
                                    {metaDataId.text[48]}
                                </span>
                                <span class="offer_Maxorder my-6 w-[18%]">
                                    {metaDataId.text[49]}
                                </span>
                                <span class="offer_rate my-6 w-[18%]">
                                    {metaDataId.text[50]}
                                </span>
                            </span>
                            {
                                
                            servicesResponse.slice(0, 10)
                                .map((service: any, j: number) => (
                                    <span class="offerList w-full flex border-b border-gray-400">
                                        <span class="offer_id line-clamp-1 my-3 w-[5%] pl-2">
                                            {j + 1}
                                        </span>
                                        <span
                                            class="offer_service line-clamp-1 my-3 w-[41%] text-left"
                                            title={service.name}
                                        >
                                            {service.name}
                                        </span>
                                        <span class="offer_Minorder line-clamp-1 my-3 w-[18%]">
                                            {service.min}
                                        </span>
                                        <span class="offer_Maxorder line-clamp-1 my-3 w-[18%]">
                                            {service.max}
                                        </span>
                                        <span class="offer_rate line-clamp-1 my-3 w-[18%]">
                                            ${service.rate}
                                        </span>
                                    </span>
                                ))}
                        </div>
                    </div>
                )
            }
        </div>

    </article>

        <section class="others-related-panels text-white hidden">
        {
            allPanelsData2.length > 0 &&
            <h2 class="text-3xl my-5 font-semibold ">{metaDataId.text[26]}</h2>
            <div id="otherPanelsHolder" class="otherPanels flex justify-center items-center gap-5 lg:flex-row flex-col">
                {/* Panels links will be added on client side */}
            </div>
        }
    </section>
</MainLayout>

<script is:inline>
    let serviceSeeAllBtn = document.querySelector("#serviceSeeAllBtn");
    if(serviceSeeAllBtn){
        serviceSeeAllBtn.addEventListener("click", ()=>{
            serviceSeeAllBtn.querySelector("i").classList.toggle("rotate-180");
    
            document.querySelectorAll(".service-card.toggle").forEach(serviceCard =>{
