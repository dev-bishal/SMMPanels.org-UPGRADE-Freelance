<style>
    .star-rating {
        display: inline-flex;
        direction: row;
    }

    .star {
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .star:hover {
        transform: scale(1.2);
    }

    .rating {
        transition: all 0.3s ease;
    }
</style>

<div class="bg-gray-50 p-4 rounded-lg">
    <div class="mb-10">
        <h3 class="text-lg font-medium text-gray-900 mb-4">Give Rating</h3>
    </div>

    <div class="bg-linear-to-r from-blue-50 to-indigo-50 rounded-xl p-6 mb-8 border border-blue-100">
        <h2 class="text-lg font-semibold text-gray-700 mb-4 text-center">
            Rate this Panel
        </h2>

        <div class="flex flex-col items-center justify-center">
            <!-- Star Rating Component -->
            <div class="star-rating mb-4" id="starRating">
                <!-- Stars will be generated by JavaScript -->
            </div>

            <!-- Rating Value Display -->
            <div class="rating text-center mt-2">
                <span class="text-sm text-gray-500">Your rating:</span>
                <span id="ratingText" class="text-lg font-semibold text-indigo-600 ml-2">0/5</span>
                <input type="hidden" id="rating" name="rating">
            </div>
        </div>
    </div>
    
</div>

<script is:inline>
    let currentRating = 0;
    let hoverRating = 0;
    document.addEventListener("DOMContentLoaded", function () {
        const starRating = document.getElementById("starRating");
        const ratingText = document.getElementById("ratingText");

        // Create 5 stars
        for (let i = 1; i <= 5; i++) {
            const star = document.createElement("span");
            star.className = "star text-4xl text-gray-300 mx-1";
            star.dataset.rating = i;
            star.innerHTML = '<i class="fas fa-star"></i>';

            // Mouse enter event
            star.addEventListener("mouseenter", function () {
                hoverRating = parseInt(this.dataset.rating);
                updateStars();
            });

            // Mouse leave event
            star.addEventListener("mouseleave", function () {
                hoverRating = 0;
                updateStars();
            });

            // Click event
            star.addEventListener("click", function () {
                currentRating = parseInt(this.dataset.rating);
                updateStars();

                // Log to console
                console.log(`Selected rating: ${currentRating}/5`);
                document.querySelector('#rating').value = currentRating;

                // Optional: Show a brief confirmation
                const originalText = ratingText.textContent;

                setTimeout(() => {
                    ratingText.textContent = originalText;
                    ratingText.classList.remove("text-green-500");
                }, 1000);
            });

            starRating.appendChild(star);
        }

        // Initialize with empty stars
        updateStars();
    });

    // Function to update star appearance
    function updateStars() {
        const stars = starRating.querySelectorAll(".star");
        const ratingToUse = hoverRating || currentRating;

        stars.forEach((star) => {
            const starValue = parseInt(star.dataset.rating);

            if (starValue <= ratingToUse) {
                star.classList.remove("text-gray-300");
                star.classList.add("text-yellow-400");
            } else {
                star.classList.remove("text-yellow-400");
                star.classList.add("text-gray-300");
            }
        });

        // Update rating text
        if (currentRating > 0) {
            ratingText.textContent = `${currentRating}/5`;
        } else {
            ratingText.textContent = "0/5";
        }
    }

    function modifyRating(value){
        currentRating = value;
        document.querySelector('#rating').value = value;
        updateStars();
    }
</script>