---

---

<style>
    .form-section {
        transition: all 0.3s ease;
    }

    .platform-header {
        cursor: pointer;
    }

    .platform-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;
    }

    .platform-content.active {
        max-height: 500px;
    }
</style>

<form id="reviewForm" class="bg-gray-50 p-4 rounded-lg shadow-md">
    <!-- TrustPilot Section -->
    <div class="form-section mb-6 border border-gray-200 rounded-lg overflow-hidden">
        <div class="platform-header bg-green-50 p-4 border-l-4 border-green-500">
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-star text-green-500 mr-3"></i>
                TrustPilot
                <i class="fas fa-chevron-down ml-auto text-gray-500 transition-transform"></i>
            </h2>
        </div>

        <div class="platform-content px-4 bg-white">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Score</label>
                    <input type="number" min="0" max="5" step="0.1"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
                        placeholder="e.g., 4.5" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Review Count</label>
                    <input type="number" min="0"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
                        placeholder="e.g., 1247" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Link</label>
                    <input type="url"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-green-500"
                        placeholder="https://trustpilot.com/..." />
                </div>
            </div>
        </div>
    </div>

    <!-- Sitejabber Section -->
    <div class="form-section mb-6 border border-gray-200 rounded-lg overflow-hidden">
        <div class="platform-header bg-purple-50 p-4 border-l-4 border-purple-500">
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-thumbs-up text-purple-500 mr-3"></i>
                Sitejabber
                <i class="fas fa-chevron-down ml-auto text-gray-500 transition-transform"></i>
            </h2>
        </div>

        <div class="platform-content px-4 bg-white">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Score</label>
                    <input type="number" min="0" max="5" step="0.1"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
                        placeholder="e.g., 4.0" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Review Count</label>
                    <input type="number" min="0"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
                        placeholder="e.g., 543" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Link</label>
                    <input type="url"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-500"
                        placeholder="https://sitejabber.com/..." />
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews.io Section -->
    <div class="form-section mb-6 border border-gray-200 rounded-lg overflow-hidden">
        <div class="platform-header bg-blue-50 p-4 border-l-4 border-blue-500">
            <h2 class="text-xl font-bold text-gray-800 flex items-center">
                <i class="fas fa-award text-blue-500 mr-3"></i>
                REVIEWS.io
                <i class="fas fa-chevron-down ml-auto text-gray-500 transition-transform"></i>
            </h2>
        </div>

        <div class="platform-content px-4 bg-white">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Score</label>
                    <input type="number" min="0" max="5" step="0.1"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="e.g., 5.0" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Review Count</label>
                    <input type="number" min="0"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="e.g., 1089" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Link</label>
                    <input type="url"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="https://reviews.io/..." />
                </div>
            </div>
        </div>
    </div>

    <div class="flex justify-end space-x-4 mt-8">
        <button type="reset"
            class="px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors">
            Reset Form
        </button>
        <button id="readRatingBtn" type="button" onclick="readOtherRatings()"
            class="hidden px-6 py-2 border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50 transition-colors">
            Read
        </button>

        <input type="hidden" name="ratingOtherSites" id="ratingOtherSites">
    </div>
</form>

<script is:inline>
    // Form submission
    let ratingOtherSites = [];
    let TrustPilotData = null;
    let SitejabberData = null;
    let ReviewsioData = null;
    // Get TrustPilot data
    const trustpilotInputs = document
        .querySelectorAll(".platform-content")[0]
        .querySelectorAll("input");

    // Get Sitejabber data
    const SitejabberInputs = document
        .querySelectorAll(".platform-content")[1]
        .querySelectorAll("input");

    // Get Reviews.io data
    const ReviewsioInputs = document
        .querySelectorAll(".platform-content")[2]
        .querySelectorAll("input");

    function readOtherRatings() {
        TrustPilotData = {
            ratingSite: "TrustPilot",
            score: trustpilotInputs[0].value,
            TotalReviews: trustpilotInputs[1].value,
            ratingURL: trustpilotInputs[2].value
        };

        SitejabberData = {
            ratingSite: "Sitejabber",
            score: SitejabberInputs[0].value,
            TotalReviews: SitejabberInputs[1].value,
            ratingURL: SitejabberInputs[2].value,
        };

        ReviewsioData = {
            ratingSite: "Reviews.io",
            score: ReviewsioInputs[0].value,
            TotalReviews: ReviewsioInputs[1].value,
            ratingURL: ReviewsioInputs[2].value,
        };

        ratingOtherSites = [];
        ratingOtherSites.push(TrustPilotData);
        ratingOtherSites.push(SitejabberData);
        ratingOtherSites.push(ReviewsioData);

        document.querySelector("#ratingOtherSites").value = JSON.stringify(ratingOtherSites);

        // console.log(ratingOtherSites);
        
    }

    document.addEventListener("DOMContentLoaded", function () {
        // Toggle platform sections
        const platformHeaders = document.querySelectorAll(".platform-header");

        platformHeaders.forEach((header) => {
            header.addEventListener("click", function () {
                const content = this.nextElementSibling;
                const icon = this.querySelector(".fa-chevron-down");

                content.classList.toggle("py-4");
                content.classList.toggle("active");
                icon.classList.toggle("rotate-180");
            });
        });
    });
</script>